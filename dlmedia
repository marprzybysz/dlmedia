#!/bin/bash
# dlmedia — TUI do pobierania z YouTube i Spotify / TUI media downloader
#
# Wymagane / Required: dialog, yt-dlp, ffmpeg, python3
# Opcjonalne / Optional (Spotify): spotdl (pipx install spotdl)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONF="$SCRIPT_DIR/dlmedia.conf"
TITLE="dlmedia"

die() { echo "$1" >&2; exit 1; }
[[ "${BASH_VERSINFO[0]:-0}" -ge 4 ]] || die "bash >= 4.0 required / wymagany bash >= 4.0 (macOS: brew install bash, then run with that bash)"
command -v python3 >/dev/null || die "python3 not found / nie znaleziono — sudo apt install python3 (needed for i18n / wymagany do tłumaczeń)"

# dialog + stdbuf are only needed for the interactive TUI, not for CLI mode.
# Checked lazily so `--url …` CLI works where they're absent (e.g. Git Bash on Windows).
require_tui() {
    command -v dialog >/dev/null || die "dialog not found / nie znaleziono — sudo apt install dialog"
    command -v stdbuf >/dev/null || die "stdbuf (GNU coreutils) not found / nie znaleziono — Debian/Ubuntu: built-in; macOS: brew install coreutils"
}

# ── Message catalog ──────────────────────────────────────────────────────────
# All user-facing strings live in locales/<lang>.json (one source of truth, also
# read by the GUI). load_lang fills the global array M from locales/${UI_LANG}.json,
# falling back to en.json. Strings containing %s are printf templates, interpolated
# at the call site. Adding a language = dropping a new <lang>.json file; no code change.
declare -A M

load_lang() {
    M=()
    local file="$SCRIPT_DIR/locales/${UI_LANG}.json"
    [[ -f "$file" ]] || file="$SCRIPT_DIR/locales/en.json"
    [[ -f "$file" ]] || die "locale file not found / brak pliku języka: $file"
    local k v
    while IFS= read -r -d '' k && IFS= read -r -d '' v; do
        M["$k"]="$v"
    done < <(python3 -c '
import json, sys
with open(sys.argv[1], encoding="utf-8") as f:
    data = json.load(f)
out = sys.stdout.buffer
for k, val in data.items():
    out.write(k.encode() + b"\0" + str(val).encode() + b"\0")
' "$file")
}

check_deps() {
    local missing=false
    local dep_list=""
    for dep in yt-dlp ffmpeg python3; do
        if command -v "$dep" >/dev/null 2>&1; then
            dep_list+="  ✓  $dep\n"
        else
            dep_list+="  ✗  $dep\n"
            missing=true
        fi
    done
    if [[ "$missing" == true ]]; then
        dialog --title "$TITLE — ${M[deps_title]}" --msgbox \
            "$(echo -e "$dep_list")\n${M[deps_footer]}" 12 55
        exit 1
    fi
}

run_setup() {
    local dl_dir fmt qual ask_fmt ask_qual qual_label pl_sub lang
    require_tui

    # ── Step 0: language (bilingual prompt, shown before UI_LANG is known) ──
    lang=$(dialog --title "$TITLE — Language / Język" --default-item "${UI_LANG:-pl}" --menu \
        "Choose language / Wybierz język:" 11 50 2 \
        "pl" "Polski" \
        "en" "English" \
        3>&1 1>&2 2>&3) || exit 0
    UI_LANG="$lang"
    load_lang

    dialog --title "$TITLE — Setup" --msgbox "${M[welcome_body]}" 13 62

    check_deps

    # Format
    fmt=$(dialog --title "$TITLE — Setup (1/4)" --default-item "${DEFAULT_FORMAT_SETUP:-ask}" --menu \
        "${M[setup_format_q]}" 14 55 3 \
        "ask" "${M[opt_ask_fmt]}" \
        "mp3" "${M[opt_audio]}" \
        "mp4" "${M[opt_video]}" \
        3>&1 1>&2 2>&3) || exit 0

    if [[ "$fmt" == "ask" ]]; then
        ask_fmt=true
        fmt="mp4"
    else
        ask_fmt=false
    fi

    # Jakość / Quality
    qual=$(dialog --title "$TITLE — Setup (2/4)" --default-item "${DEFAULT_QUALITY_SETUP:-ask}" --menu \
        "${M[setup_quality_q]}" 14 55 4 \
        "ask"    "${M[opt_ask_qual]}" \
        "best"   "${M[opt_best]}" \
        "medium" "${M[opt_medium]}" \
        "lowest" "${M[opt_lowest]}" \
        3>&1 1>&2 2>&3) || exit 0

    if [[ "$qual" == "ask" ]]; then
        ask_qual=true
        qual="best"
        qual_label="${M[lbl_always_ask]}"
    elif [[ "$qual" == "best" ]]; then
        ask_qual=false
        [[ "$fmt" == "mp3" ]] && qual="320"
        qual_label="${M[lbl_best]}"
    elif [[ "$qual" == "medium" ]]; then
        ask_qual=false
        [[ "$fmt" == "mp4" ]] && qual="720" || qual="192"
        qual_label="${M[lbl_medium]}"
    elif [[ "$qual" == "lowest" ]]; then
        ask_qual=false
        [[ "$fmt" == "mp4" ]] && qual="360" || qual="128"
        qual_label="${M[lbl_lowest]}"
    fi

    # Folder
    local dir_choice
    dir_choice=$(dialog --title "$TITLE — Setup (3/4)" --default-item "custom" --menu \
        "${M[setup_folder_q]}" 14 55 3 \
        "custom"    "${M[opt_custom_path]}" \
        "subfolder" "${M[opt_subfolder]}" \
        "current"   "${M[opt_current]}" \
        3>&1 1>&2 2>&3) || exit 0

    case "$dir_choice" in
        current)   dl_dir="." ;;
        subfolder) dl_dir="./dlm-media" ;;
        custom)
            dl_dir=$(dialog --title "$TITLE — Setup (3/4)" --inputbox "${M[folder_path_prompt]}" 10 70 \
                3>&1 1>&2 2>&3) || exit 0
            ;;
    esac

    # Subfoldery playlist / Playlist subfolders
    pl_sub=$(dialog --title "$TITLE — Setup (4/4)" --default-item "yes" --menu \
        "${M[setup_subf_q]}" 12 55 2 \
        "yes" "${M[opt_yes]}" \
        "no"  "${M[opt_no_onefolder]}" \
        3>&1 1>&2 2>&3) || exit 0

    [[ "$pl_sub" == "yes" ]] && pl_sub=true || pl_sub=false

    cat > "$CONF" << EOF
# dlmedia — configuration / konfiguracja
# Edit this file or run / Edytuj ten plik lub uruchom: ./dlmedia --setup
# https://github.com/marprzybysz/dlmedia

UI_LANG="$UI_LANG"
DOWNLOAD_DIR="$dl_dir"
DEFAULT_FORMAT="$fmt"
DEFAULT_QUALITY="$qual"
ASK_FORMAT=$ask_fmt
ASK_QUALITY=$ask_qual
PLAYLIST_SUBFOLDERS=$pl_sub
EOF

    local fmt_label="$fmt"
    [[ "$ask_fmt" == true ]] && fmt_label="${M[lbl_always_ask]}"
    local sub_label
    [[ "$pl_sub" == true ]] && sub_label="${M[lbl_yes]}" || sub_label="${M[lbl_no]}"

    dialog --title "$TITLE — ${M[setup_done_title]}" --msgbox \
        "$(printf "${M[setup_done_body]}" "$fmt_label" "$qual_label" "$dl_dir" "$sub_label")" \
        14 65
}

# Build yt-dlp format/quality flags into the global `args` array. Shared by TUI + CLI
# so the selector logic lives in one place.
build_yt_args() {
    local format="$1" quality="$2" fmt
    if [[ "$format" == "mp4" ]]; then
        # Codec-agnostic so 4K/8K (VP9/AV1) isn't capped to ~1080p H.264;
        # --merge-output-format mp4 remuxes the result into an .mp4 container.
        case "$quality" in
            best) fmt="-f bestvideo+bestaudio/best" ;;
            *)    fmt="-f bestvideo[height<=${quality}]+bestaudio/best[height<=${quality}]/best" ;;
        esac
        args=($fmt --merge-output-format mp4)
    else
        args=(-x --audio-format mp3 --audio-quality "${quality}K")
    fi
}

# Non-interactive CLI: no dialog, no stdbuf. Output streams to the terminal and the
# exit code reflects the downloader — so scripts/automation (and Git Bash on Windows)
# can call dlmedia without the TUI. Reuses build_yt_args + the i18n catalog.
cli_main() {
    local url="" format="" quality="" out=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url)     url="$2";     shift 2 ;;
            --format)  format="$2";  shift 2 ;;
            --quality) quality="$2"; shift 2 ;;
            --out)     out="$2";     shift 2 ;;
            --lang)    UI_LANG="$2"; load_lang; shift 2 ;;
            *) die "$(printf "${M[cli_bad_arg]}" "$1")" ;;
        esac
    done
    [[ -n "$url" ]] || die "${M[err_no_url]}"
    format="${format:-${DEFAULT_FORMAT:-mp4}}"
    [[ "$format" == "mp3" || "$format" == "mp4" ]] || die "${M[cli_bad_format]}"
    out="${out:-$DOWNLOAD_DIR}"
    mkdir -p "$out"

    if [[ "$url" == *"open.spotify.com"* || "$url" == *"spotify.link"* ]]; then
        command -v spotdl >/dev/null || die "${M[err_spotdl]}"
        [[ -n "$quality" ]] || quality="320"
        spotdl --bitrate "${quality}k" --output "$out/{artist} - {title}" "$url"
        return $?
    fi

    command -v yt-dlp >/dev/null || die "yt-dlp not found / nie znaleziono"
    if [[ -z "$quality" ]]; then
        [[ "$format" == "mp4" ]] && quality="best" || quality="320"
    fi
    build_yt_args "$format" "$quality"
    yt-dlp "${args[@]}" -o "$out/%(title)s.%(ext)s" "$url"
    return $?
}

# Test hook: `DLMEDIA_LIB=1 source dlmedia` defines the functions above without
# running the app, so tests/ can exercise build_yt_args / cli_main / load_lang.
[[ -n "${DLMEDIA_LIB:-}" ]] && return 0 2>/dev/null

UI_LANG="pl"
DOWNLOAD_DIR="/mnt/c/Users/$(whoami)/Downloads/yt-dlp"
DEFAULT_FORMAT=""
DEFAULT_QUALITY=""
ASK_FORMAT=true
ASK_QUALITY=true
PLAYLIST_SUBFOLDERS=true

[[ -f "$CONF" ]] && source "$CONF"
load_lang

mkdir -p "$DOWNLOAD_DIR"


case "${1:-}" in
    --url)    cli_main "$@"; exit $? ;;
    --update) echo "${M[updating]}"; yt-dlp --update; exit $? ;;
    --setup)  run_setup; source "$CONF"; exit 0 ;;
    --help)   echo "${M[help]}"; exit 0 ;;
esac

if [[ ! -f "$CONF" ]]; then
    run_setup
    source "$CONF"
    load_lang
fi

require_tui
check_deps

while true; do

url=$(dialog --title "$TITLE" --cancel-label "Exit" --inputbox "${M[url_prompt]}" 10 70 3>&1 1>&2 2>&3) || exit 0
[[ -z "$url" ]] && die "${M[err_no_url]}"

if [[ "$url" == *"open.spotify.com"* || "$url" == *"spotify.link"* ]]; then
    command -v spotdl >/dev/null || die "${M[err_spotdl]}"

    quality=$(dialog --title "$TITLE — Spotify" --menu "${M[audio_quality_q]}" 14 50 3 \
        "320" "${M[q320]}" \
        "192" "192 kbps" \
        "128" "128 kbps" \
        3>&1 1>&2 2>&3) || exit 0

    dialog --title "$TITLE" --infobox "${M[spot_fetching]}" 5 50
    spot_save="/tmp/dlmedia_spot_$$.spotdl"
    spotdl save "$url" --save-file "$spot_save" >/dev/null 2>&1
    mapfile -t spot_tracks < <(python3 -c "
import json,sys
data=json.load(open('$spot_save'))
for s in data:
    print(f\"{s['artist']} - {s['name']}\")
" 2>/dev/null)
    spot_count=${#spot_tracks[@]}

    if [[ $spot_count -eq 0 ]]; then
        rm -f "$spot_save"
        die "${M[err_spot_list]}"
    fi

    spot_list=""
    for i in "${!spot_tracks[@]}"; do
        spot_list+="$((i+1)). ${spot_tracks[$i]}\n"
    done
    spot_list+="─────────────────────────────\n$(printf "${M[spot_footer]}" "$quality" "$DOWNLOAD_DIR")"

    max_h=$(($(tput lines) - 4))
    box_h=$((spot_count + 10))
    [[ $box_h -gt $max_h ]] && box_h=$max_h

    dialog --title "$TITLE — Spotify ($spot_count ${M[word_tracks]})" --yes-label "${M[btn_download]}" --no-label "${M[btn_cancel]}" \
        --yesno "$(echo -e "$spot_list")" $box_h 70 3>&1 1>&2 2>&3 || exit 0

    overwrite_args=()
    if [[ "$PLAYLIST_SUBFOLDERS" == true ]]; then
        spot_output="${DOWNLOAD_DIR}/{list-name}/{artist} - {title}"
    else
        spot_output="${DOWNLOAD_DIR}/{artist} - {title}"
    fi
    list_name=$(python3 -c "import json; data=json.load(open('$spot_save')); print(data[0].get('list_name',''))" 2>/dev/null)
    spot_subdir="${DOWNLOAD_DIR}/${list_name}"
    existing=$(find "$spot_subdir" -name "*.mp3" 2>/dev/null | head -1)
    if [[ -n "$list_name" && -n "$existing" ]]; then
        ow_mode=$(dialog --title "$TITLE" --menu "${M[ow_q]}" 12 55 2 \
            "skip"      "${M[ow_skip]}" \
            "overwrite" "${M[ow_overwrite]}" \
            3>&1 1>&2 2>&3) || exit 0
        [[ "$ow_mode" == "skip" ]] && overwrite_args=(--skip-existing)
    fi

    log="/tmp/dlmedia_spot_$$.log"
    stdbuf -oL spotdl "${overwrite_args[@]}" --bitrate "${quality}k" --output "$spot_output" "$url" 2>&1 | tee "$log" | dialog --title "$TITLE — ${M[downloading]} ($spot_count ${M[word_tracks]})" --programbox 20 78

    failed=$(grep -i "error\|failed\|skipping" "$log" | grep -iv "skipping.*existing" || true)
    downloaded=$(grep -c "^Downloaded" "$log" || echo 0)
    rm -f "$log" "$spot_save"

    summary="$(printf "${M[summary_spot]}" "$downloaded" "$spot_count")"
    if [[ -n "$failed" ]]; then
        summary+="\n\n${M[summary_failed_hdr]}\n$failed"
    else
        summary+="\n\n${M[summary_all_ok]}"
    fi
    fail_lines=$(echo "$failed" | wc -l)
    [[ -z "$failed" ]] && fail_lines=0
    dialog --title "$TITLE — ${M[summary_title]}" --yes-label "${M[btn_back]}" --no-label "Exit" \
        --yesno "$summary" $((fail_lines + 10)) 70 && continue || exit 0
fi

playlist_args=()
if [[ "$url" == *"list="* || "$url" == *"/playlist"* || "$url" == *"/sets/"* ]]; then
    dialog --title "$TITLE" --infobox "${M[pl_fetching]}" 5 40
    mapfile -t titles < <(yt-dlp --flat-playlist --print "%(playlist_index)s. %(title)s" "$url" 2>/dev/null)
    count=${#titles[@]}

    if [[ $count -eq 0 ]]; then
        die "${M[err_pl_list]}"
    fi

    list_text=""
    for t in "${titles[@]}"; do
        list_text+="$t\n"
    done

    max_h=$(($(tput lines) - 4))
    box_h=$((count + 12))
    [[ $box_h -gt $max_h ]] && box_h=$max_h
    menu_h=$((box_h - 8))
    [[ $menu_h -lt 4 ]] && menu_h=4

    pl_mode=$(dialog --title "$TITLE — ${M[playlist]} ($count ${M[word_videos]})" --menu \
        "$(echo -e "$list_text")\n─────────────────────────────\n${M[pl_what]}" \
        $box_h 70 $menu_h \
        "all"    "${M[pl_all]}" \
        "pick"   "${M[pl_pick]}" \
        "range"  "${M[pl_range]}" \
        "single" "${M[pl_single]}" \
        3>&1 1>&2 2>&3) || exit 0

    case "$pl_mode" in
        all)
            playlist_args=(--yes-playlist)
            ;;
        pick)
            checklist_args=()
            for t in "${titles[@]}"; do
                num="${t%%.*}"
                name="${t#*. }"
                checklist_args+=("$num" "$name" "OFF")
            done
            box_h=$((count + 8))
            [[ $box_h -gt $max_h ]] && box_h=$max_h
            list_h=$((box_h - 6))
            [[ $list_h -lt 4 ]] && list_h=4
            picked=$(dialog --title "$TITLE" --checklist "${M[checklist_hint]}" \
                $box_h 70 $list_h \
                "${checklist_args[@]}" \
                3>&1 1>&2 2>&3) || exit 0
            [[ -z "$picked" ]] && die "${M[err_no_pick]}"
            items=$(echo "$picked" | tr -d '"' | tr ' ' ',')
            playlist_args=(--yes-playlist --playlist-items "$items")
            ;;
        range)
            range=$(dialog --title "$TITLE" --inputbox "${M[range_prompt]}" 10 50 3>&1 1>&2 2>&3) || exit 0
            [[ -z "$range" ]] && die "${M[err_no_range]}"
            playlist_args=(--yes-playlist --playlist-items "$range")
            ;;
        single)
            playlist_args=(--no-playlist)
            ;;
    esac
fi

if [[ "$ASK_FORMAT" == true ]]; then
    format=$(dialog --title "$TITLE" --default-item "${DEFAULT_FORMAT:-mp4}" --menu "${M[format_q]}" 12 40 2 \
        "mp3" "${M[opt_audio]}" \
        "mp4" "${M[opt_video]}" \
        3>&1 1>&2 2>&3) || exit 0
else
    format="${DEFAULT_FORMAT:-mp4}"
fi

if [[ "$format" == "mp4" ]]; then
    if [[ "$ASK_QUALITY" == true ]]; then
        quality=$(dialog --title "$TITLE" --default-item "${DEFAULT_QUALITY:-best}" --menu "${M[video_quality_q]}" 19 52 8 \
            "best"  "${M[opt_best]}" \
            "4320"  "4320p (8K)" \
            "2160"  "2160p (4K)" \
            "1440"  "1440p (2K)" \
            "1080"  "1080p (Full HD)" \
            "720"   "720p (HD)" \
            "480"   "480p (SD)" \
            "360"   "360p" \
            3>&1 1>&2 2>&3) || exit 0
    else
        quality="${DEFAULT_QUALITY:-best}"
    fi
else
    if [[ "$ASK_QUALITY" == true ]]; then
        quality=$(dialog --title "$TITLE" --default-item "${DEFAULT_QUALITY:-320}" --menu "${M[audio_quality_q]}" 14 50 3 \
            "320" "${M[q320]}" \
            "192" "192 kbps" \
            "128" "128 kbps" \
            3>&1 1>&2 2>&3) || exit 0
    else
        quality="${DEFAULT_QUALITY:-320}"
    fi
fi

build_yt_args "$format" "$quality"

is_playlist=false
if [[ ${#playlist_args[@]} -gt 0 && "${playlist_args[0]}" != "--no-playlist" ]]; then
    is_playlist=true
fi

if [[ "$is_playlist" == false ]]; then
    dialog --title "$TITLE" --infobox "${M[info_fetching]}" 5 40
    info=$(yt-dlp --no-playlist --print "%(title)s\n%(duration_string)s\n%(filesize_approx,filesize)s" "$url" 2>/dev/null)
    v_title=$(echo "$info" | sed -n '1p')
    v_duration=$(echo "$info" | sed -n '2p')
    v_size=$(echo "$info" | sed -n '3p')

    [[ "$v_size" == "NA" || -z "$v_size" ]] && v_size="${M[size_unknown]}" || v_size=$(numfmt --to=iec "$v_size" 2>/dev/null || echo "$v_size")

    dialog --title "$TITLE — ${M[preview_title]}" --yes-label "${M[btn_download]}" --no-label "${M[btn_cancel]}" --yesno \
        "$(printf "${M[preview_body]}" "$v_title" "$v_duration" "$v_size" "$format" "$quality")" \
        12 70 3>&1 1>&2 2>&3 || exit 0
fi

if [[ "$is_playlist" == true ]]; then
    if [[ "$PLAYLIST_SUBFOLDERS" == true ]]; then
        output="${DOWNLOAD_DIR}/%(playlist_title)s/%(title)s.%(ext)s"
    else
        output="${DOWNLOAD_DIR}/%(title)s.%(ext)s"
    fi
    pl_name=$(yt-dlp --flat-playlist --print "%(playlist_title)s" "$url" 2>/dev/null | head -1)
    pl_subdir="${DOWNLOAD_DIR}/${pl_name}"
    existing=$(find "$pl_subdir" -name "*.mp4" -o -name "*.mp3" 2>/dev/null | head -1)
    if [[ -n "$pl_name" && -n "$existing" ]]; then
        ow_mode=$(dialog --title "$TITLE" --menu "${M[ow_q]}" 12 55 2 \
            "skip"      "${M[ow_skip]}" \
            "overwrite" "${M[ow_overwrite]}" \
            3>&1 1>&2 2>&3) || exit 0
    fi
else
    output="${DOWNLOAD_DIR}/%(title)s.%(ext)s"
fi

yt_extra_args=()
if [[ "${ow_mode:-}" == "skip" ]]; then
    yt_extra_args=(--download-archive "${DOWNLOAD_DIR}/.ytdl-archive")
fi

log="/tmp/dlmedia_yt_$$.log"
dl_title="${M[downloading]}"
[[ "$is_playlist" == true ]] && dl_title="${M[downloading]} (${count:-} ${M[word_videos]})"

stdbuf -oL yt-dlp --newline "${playlist_args[@]}" "${args[@]}" "${yt_extra_args[@]}" -o "$output" "$url" 2>&1 | tee "$log" | dialog --title "$TITLE — $dl_title" --programbox 20 78

failed=$(grep -iE "ERROR:|unable to download" "$log" || true)
downloaded=$(grep -c "\[download\] Destination:" "$log" 2>/dev/null || true)
skipped=$(grep -c "has already been recorded" "$log" 2>/dev/null || true)
[[ -z "$downloaded" ]] && downloaded=0
[[ -z "$skipped" ]] && skipped=0
rm -f "$log"

summary="$(printf "${M[summary_yt]}" "$downloaded" "$skipped")"
if [[ -n "$failed" ]]; then
    summary+="\n\n${M[summary_failed_hdr]}\n$failed"
else
    summary+="\n\n${M[summary_all_ok]}"
fi
fail_lines=$(echo "$failed" | wc -l)
[[ -z "$failed" ]] && fail_lines=0
dialog --title "$TITLE — ${M[summary_title]}" --yes-label "${M[btn_back]}" --no-label "Exit" \
    --yesno "$summary" $((fail_lines + 10)) 80 && continue || exit 0

done
