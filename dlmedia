#!/bin/bash
# dlmedia — TUI do pobierania z YouTube i Spotify / TUI media downloader
#
# Wymagane / Required: dialog, yt-dlp, ffmpeg, python3
# Opcjonalne / Optional (Spotify): spotdl (pipx install spotdl)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONF="$SCRIPT_DIR/dlmedia.conf"
TITLE="dlmedia"

die() { echo "$1" >&2; exit 1; }
[[ "${BASH_VERSINFO[0]:-0}" -ge 4 ]] || die "bash >= 4.0 required / wymagany bash >= 4.0 (macOS: brew install bash, then run with that bash)"
command -v python3 >/dev/null || die "python3 not found / nie znaleziono — sudo apt install python3 (needed for i18n / wymagany do tłumaczeń)"

# dialog + stdbuf are only needed for the interactive TUI, not for CLI mode.
# Checked lazily so `--url …` CLI works where they're absent (e.g. Git Bash on Windows).
require_tui() {
    command -v dialog >/dev/null || die "dialog not found / nie znaleziono — sudo apt install dialog"
    command -v stdbuf >/dev/null || die "stdbuf (GNU coreutils) not found / nie znaleziono — Debian/Ubuntu: built-in; macOS: brew install coreutils"
}

# ── Message catalog ──────────────────────────────────────────────────────────
# All user-facing strings live in locales/<lang>.json (one source of truth, also
# read by the GUI). load_lang fills the global array M from locales/${UI_LANG}.json,
# falling back to en.json. Strings containing %s are printf templates, interpolated
# at the call site. Adding a language = dropping a new <lang>.json file; no code change.
declare -A M

load_lang() {
    M=()
    local file="$SCRIPT_DIR/locales/${UI_LANG}.json"
    [[ -f "$file" ]] || file="$SCRIPT_DIR/locales/en.json"
    [[ -f "$file" ]] || die "locale file not found / brak pliku języka: $file"
    local k v
    while IFS= read -r -d '' k && IFS= read -r -d '' v; do
        M["$k"]="$v"
    done < <(python3 -c '
import json, sys
with open(sys.argv[1], encoding="utf-8") as f:
    data = json.load(f)
out = sys.stdout.buffer
for k, val in data.items():
    out.write(k.encode() + b"\0" + str(val).encode() + b"\0")
' "$file")
}

check_deps() {
    local missing=false
    local dep_list=""
    for dep in yt-dlp ffmpeg python3; do
        if command -v "$dep" >/dev/null 2>&1; then
            dep_list+="  ✓  $dep\n"
        else
            dep_list+="  ✗  $dep\n"
            missing=true
        fi
    done
    if [[ "$missing" == true ]]; then
        dialog --title "$TITLE — ${M[deps_title]}" --msgbox \
            "$(echo -e "$dep_list")\n${M[deps_footer]}" 12 55
        exit 1
    fi
}

run_setup() {
    local dl_dir fmt qual ask_fmt ask_qual qual_label pl_sub lang
    require_tui

    # ── Step 0: language (bilingual prompt, shown before UI_LANG is known) ──
    lang=$(dialog --title "$TITLE — Language / Język" --default-item "${UI_LANG:-pl}" --menu \
        "Choose language / Wybierz język:" 11 50 2 \
        "pl" "Polski" \
        "en" "English" \
        3>&1 1>&2 2>&3) || exit 0
    UI_LANG="$lang"
    load_lang

    dialog --title "$TITLE — Setup" --msgbox "${M[welcome_body]}" 13 62

    check_deps

    # Format
    fmt=$(dialog --title "$TITLE — Setup (1/4)" --default-item "${DEFAULT_FORMAT_SETUP:-ask}" --menu \
        "${M[setup_format_q]}" 14 55 3 \
        "ask" "${M[opt_ask_fmt]}" \
        "mp3" "${M[opt_audio]}" \
        "mp4" "${M[opt_video]}" \
        3>&1 1>&2 2>&3) || exit 0

    if [[ "$fmt" == "ask" ]]; then
        ask_fmt=true
        fmt="mp4"
    else
        ask_fmt=false
    fi

    # Jakość / Quality
    qual=$(dialog --title "$TITLE — Setup (2/4)" --default-item "${DEFAULT_QUALITY_SETUP:-ask}" --menu \
        "${M[setup_quality_q]}" 14 55 4 \
        "ask"    "${M[opt_ask_qual]}" \
        "best"   "${M[opt_best]}" \
        "medium" "${M[opt_medium]}" \
        "lowest" "${M[opt_lowest]}" \
        3>&1 1>&2 2>&3) || exit 0

    if [[ "$qual" == "ask" ]]; then
        ask_qual=true
        qual="best"
        qual_label="${M[lbl_always_ask]}"
    elif [[ "$qual" == "best" ]]; then
        ask_qual=false
        [[ "$fmt" == "mp3" ]] && qual="320"
        qual_label="${M[lbl_best]}"
    elif [[ "$qual" == "medium" ]]; then
        ask_qual=false
        [[ "$fmt" == "mp4" ]] && qual="720" || qual="192"
        qual_label="${M[lbl_medium]}"
    elif [[ "$qual" == "lowest" ]]; then
        ask_qual=false
        [[ "$fmt" == "mp4" ]] && qual="360" || qual="128"
        qual_label="${M[lbl_lowest]}"
    fi

    # Folder
    local dir_choice
    dir_choice=$(dialog --title "$TITLE — Setup (3/4)" --default-item "custom" --menu \
        "${M[setup_folder_q]}" 14 55 3 \
        "custom"    "${M[opt_custom_path]}" \
        "subfolder" "${M[opt_subfolder]}" \
        "current"   "${M[opt_current]}" \
        3>&1 1>&2 2>&3) || exit 0

    case "$dir_choice" in
        current)   dl_dir="." ;;
        subfolder) dl_dir="./dlm-media" ;;
        custom)
            dl_dir=$(dialog --title "$TITLE — Setup (3/4)" --inputbox "${M[folder_path_prompt]}" 10 70 \
                3>&1 1>&2 2>&3) || exit 0
            ;;
    esac

    # Subfoldery playlist / Playlist subfolders
    pl_sub=$(dialog --title "$TITLE — Setup (4/4)" --default-item "yes" --menu \
        "${M[setup_subf_q]}" 12 55 2 \
        "yes" "${M[opt_yes]}" \
        "no"  "${M[opt_no_onefolder]}" \
        3>&1 1>&2 2>&3) || exit 0

    [[ "$pl_sub" == "yes" ]] && pl_sub=true || pl_sub=false

    cat > "$CONF" << EOF
# dlmedia — configuration / konfiguracja
# Edit this file or run / Edytuj ten plik lub uruchom: ./dlmedia --setup
# https://github.com/marprzybysz/dlmedia

UI_LANG="$UI_LANG"
DOWNLOAD_DIR="$dl_dir"
DEFAULT_FORMAT="$fmt"
DEFAULT_QUALITY="$qual"
ASK_FORMAT=$ask_fmt
ASK_QUALITY=$ask_qual
PLAYLIST_SUBFOLDERS=$pl_sub
EOF

    local fmt_label="$fmt"
    [[ "$ask_fmt" == true ]] && fmt_label="${M[lbl_always_ask]}"
    local sub_label
    [[ "$pl_sub" == true ]] && sub_label="${M[lbl_yes]}" || sub_label="${M[lbl_no]}"

    dialog --title "$TITLE — ${M[setup_done_title]}" --msgbox \
        "$(printf "${M[setup_done_body]}" "$fmt_label" "$qual_label" "$dl_dir" "$sub_label")" \
        14 65
}

# Human-friendly file size: bytes -> "23.4 MB" / "1.50 GB" (1024-based, friendly labels).
# Non-numeric input passes through unchanged (e.g. yt-dlp's "NA").
human_size() {
    local b="$1"
    [[ "$b" =~ ^[0-9]+$ ]] || { printf '%s' "$b"; return; }
    if [[ "$b" -ge 1073741824 ]]; then
        awk -v b="$b" 'BEGIN{printf "%.2f GB", b/1073741824}'
    else
        awk -v b="$b" 'BEGIN{printf "%.1f MB", b/1048576}'
    fi
}

# Map a dialog exit code to a navigation action (for the step-machine main loop).
# dialog returns: OK=0, Cancel=1, Extra(=Back)=3, ESC=255.
nav_action() {
    case "$1" in
        0) echo next ;;
        3) echo back ;;
        1) echo cancel ;;
        *) echo exit ;;
    esac
}

# Ordered decision-screen list for a task, given branch + ASK_FORMAT/ASK_QUALITY.
# Skips format/quality when their ASK flag isn't "true" (Spotify always asks quality).
# Pure/echo-only → unit-tested.
build_steps() {
    local branch="$1" ask_format="$2" ask_quality="$3" s
    local list=() out=()
    case "$branch" in
        single)  list=(format quality preview) ;;
        ytlist)  list=(checklist format quality) ;;
        spotify) list=(spotchecklist spotquality) ;;
    esac
    for s in "${list[@]}"; do
        [[ "$s" == "format"  && "$ask_format"  != "true" ]] && continue
        [[ "$s" == "quality" && "$ask_quality" != "true" ]] && continue
        out+=("$s")
    done
    echo "${out[@]}"
}

# Checklist state for item $1 given a saved CSV selection $2. Empty CSV = all ON
# (first visit). Lets a checklist remember what was ticked when you navigate Back.
sel_state() {
    local n="$1" csv="$2"
    [[ -z "$csv" ]] && { echo ON; return; }
    case ",$csv," in *",$n,"*) echo ON ;; *) echo OFF ;; esac
}

# Build yt-dlp format/quality flags into the global `args` array. Shared by TUI + CLI
# so the selector logic lives in one place.
build_yt_args() {
    local format="$1" quality="$2" fmt
    if [[ "$format" == "mp4" ]]; then
        # Codec-agnostic so 4K/8K (VP9/AV1) isn't capped to ~1080p H.264;
        # --merge-output-format mp4 remuxes the result into an .mp4 container.
        case "$quality" in
            best) fmt="-f bestvideo+bestaudio/best" ;;
            *)    fmt="-f bestvideo[height<=${quality}]+bestaudio/best[height<=${quality}]/best" ;;
        esac
        args=($fmt --merge-output-format mp4)
    else
        args=(-x --audio-format mp3 --audio-quality "${quality}K")
    fi
}

# Non-interactive CLI: no dialog, no stdbuf. Output streams to the terminal and the
# exit code reflects the downloader — so scripts/automation (and Git Bash on Windows)
# can call dlmedia without the TUI. Reuses build_yt_args + the i18n catalog.
cli_main() {
    local url="" format="" quality="" out=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --url)     url="$2";     shift 2 ;;
            --format)  format="$2";  shift 2 ;;
            --quality) quality="$2"; shift 2 ;;
            --out)     out="$2";     shift 2 ;;
            --lang)    UI_LANG="$2"; load_lang; shift 2 ;;
            *) die "$(printf "${M[cli_bad_arg]}" "$1")" ;;
        esac
    done
    [[ -n "$url" ]] || die "${M[err_no_url]}"
    format="${format:-${DEFAULT_FORMAT:-mp4}}"
    [[ "$format" == "mp3" || "$format" == "mp4" ]] || die "${M[cli_bad_format]}"
    out="${out:-$DOWNLOAD_DIR}"
    mkdir -p "$out"

    if [[ "$url" == *"open.spotify.com"* || "$url" == *"spotify.link"* ]]; then
        command -v spotdl >/dev/null || die "${M[err_spotdl]}"
        [[ -n "$quality" ]] || quality="320"
        spotdl --bitrate "${quality}k" --output "$out/{artist} - {title}" "$url"
        return $?
    fi

    command -v yt-dlp >/dev/null || die "yt-dlp not found / nie znaleziono"
    if [[ -z "$quality" ]]; then
        [[ "$format" == "mp4" ]] && quality="best" || quality="320"
    fi
    build_yt_args "$format" "$quality"
    yt-dlp "${args[@]}" -o "$out/%(title)s.%(ext)s" "$url"
    return $?
}

# Test hook: `DLMEDIA_LIB=1 source dlmedia` defines the functions above without
# running the app, so tests/ can exercise build_yt_args / cli_main / load_lang.
[[ -n "${DLMEDIA_LIB:-}" ]] && return 0 2>/dev/null

UI_LANG="pl"
DOWNLOAD_DIR="/mnt/c/Users/$(whoami)/Downloads/yt-dlp"
DEFAULT_FORMAT=""
DEFAULT_QUALITY=""
ASK_FORMAT=true
ASK_QUALITY=true
PLAYLIST_SUBFOLDERS=true

[[ -f "$CONF" ]] && source "$CONF"
load_lang

mkdir -p "$DOWNLOAD_DIR"


case "${1:-}" in
    --url)    cli_main "$@"; exit $? ;;
    --update) echo "${M[updating]}"; yt-dlp --update; exit $? ;;
    --setup)  run_setup; source "$CONF"; exit 0 ;;
    --help)   echo "${M[help]}"; exit 0 ;;
esac

if [[ ! -f "$CONF" ]]; then
    run_setup
    source "$CONF"
    load_lang
fi

require_tui
check_deps

while true; do   # ── TASK LOOP: re-entry on new URL / Anuluj / Wstecz-from-first ──

# URL screen: OK→start; Cancel-label "Exit"/ESC→quit; no Back. Field starts EMPTY —
# coming back here (Powrót/Anuluj/Wstecz) you usually want a fresh link, not to edit the old one.
url=$(dialog --title "$TITLE" --cancel-label "Exit" --inputbox "${M[url_prompt]}" 10 70 "" 3>&1 1>&2 2>&3) || exit 0
[[ -z "$url" ]] && continue

if [[ "$url" == *"open.spotify.com"* || "$url" == *"spotify.link"* ]]; then
    if ! command -v spotdl >/dev/null; then     # recoverable → dialog, back to URL (stay in app)
        dialog --title "$TITLE" --msgbox "${M[err_spotdl]}" 7 60
        continue
    fi
    branch="spotify"
elif [[ "$url" == *"list="* || "$url" == *"/playlist"* || "$url" == *"/sets/"* ]]; then
    branch="ytlist"
else
    branch="single"
fi

# New URL → forget remembered picks + cached metadata (cache is keyed by URL).
if [[ "$url" != "${last_url:-}" ]]; then
    last_url="$url"; fetched=""; format=""; quality=""; yt_sel=""; spot_sel=""
    playlist_args=()
fi

# Decision screens as an ordered, index-navigable list (Wstecz=back, Anuluj/ESC handled below).
read -ra steps <<< "$(build_steps "$branch" "$ASK_FORMAT" "$ASK_QUALITY")"
i=0
while [[ $i -ge 0 && $i -lt ${#steps[@]} ]]; do
    nav=""
    case "${steps[$i]}" in

    spotchecklist)
        if [[ -z "$fetched" ]]; then        # fetch once per URL (cache via $fetched/$last_url)
            dialog --title "$TITLE" --infobox "${M[spot_fetching]}" 5 50
            spot_save="/tmp/dlmedia_spot_$$.spotdl"
            spotdl save "$url" --save-file "$spot_save" >/dev/null 2>&1
            mapfile -t spot_tracks < <(python3 -c "
import json,sys
data=json.load(open('$spot_save'))
for s in data:
    print(f\"{s['artist']} - {s['name']}\")
" 2>/dev/null)
            spot_count=${#spot_tracks[@]}
            if [[ $spot_count -eq 0 ]]; then
                rm -f "$spot_save"
                dialog --title "$TITLE" --msgbox "${M[err_spot_list]}" 7 50
                nav="cancel"
            else
                fetched=1
            fi
        fi
        if [[ -z "$nav" ]]; then
            checklist_args=()
            for n in "${!spot_tracks[@]}"; do
                checklist_args+=("$((n+1))" "${spot_tracks[$n]}" "$(sel_state "$((n+1))" "$spot_sel")")
            done
            max_h=$(($(tput lines) - 4))
            box_h=$((spot_count + 8)); [[ $box_h -gt $max_h ]] && box_h=$max_h
            list_h=$((box_h - 6)); [[ $list_h -lt 4 ]] && list_h=4
            picked=$(dialog --title "$TITLE — Spotify ($spot_count ${M[word_tracks]})" \
                --extra-button --extra-label "${M[btn_step_back]}" --cancel-label "${M[btn_cancel]}" \
                --checklist "${M[checklist_hint]}" $box_h 74 $list_h \
                "${checklist_args[@]}" 3>&1 1>&2 2>&3)
            nav=$(nav_action $?)
            if [[ "$nav" == "next" ]]; then
                if [[ -z "$picked" ]]; then
                    dialog --title "$TITLE" --msgbox "${M[spot_no_pick]}" 7 50; nav="stay"
                else
                    spot_sel=$(echo "$picked" | tr -d '"' | tr ' ' ',')
                fi
            fi
        fi
        ;;

    spotquality)
        sel=$(dialog --title "$TITLE — Spotify" --default-item "${quality:-320}" \
            --extra-button --extra-label "${M[btn_step_back]}" --cancel-label "${M[btn_cancel]}" \
            --menu "${M[audio_quality_q]}" 14 50 3 \
            "320" "${M[q320]}" \
            "192" "192 kbps" \
            "128" "128 kbps" 3>&1 1>&2 2>&3)
        nav=$(nav_action $?)
        [[ "$nav" == "next" ]] && quality="$sel"
        ;;

    checklist)
        if [[ -z "$fetched" ]]; then
            dialog --title "$TITLE" --infobox "${M[pl_fetching]}" 5 40
            # Capture id + "index. title" (two --print lines per item) so the failure
            # report can pair an ERROR's video id back to its title. yt_ids_file = id<TAB>title.
            mapfile -t _raw < <(yt-dlp --flat-playlist --print "%(id)s" --print "%(playlist_index)s. %(title)s" "$url" 2>/dev/null)
            yt_ids_file="/tmp/dlmedia_ytids_$$.tsv"; : > "$yt_ids_file"
            titles=()
            for ((_k=0; _k+1 < ${#_raw[@]}; _k+=2)); do
                printf '%s\t%s\n' "${_raw[_k]}" "${_raw[_k+1]}" >> "$yt_ids_file"
                titles+=("${_raw[_k+1]}")
            done
            count=${#titles[@]}
            if [[ $count -eq 0 ]]; then
                dialog --title "$TITLE" --msgbox "${M[err_pl_list]}" 7 50
                nav="cancel"
            else
                fetched=1
            fi
        fi
        if [[ -z "$nav" ]]; then
            checklist_args=()
            for t in "${titles[@]}"; do
                num="${t%%.*}"; name="${t#*. }"
                checklist_args+=("$num" "$name" "$(sel_state "$num" "$yt_sel")")
            done
            max_h=$(($(tput lines) - 4))
            box_h=$((count + 8)); [[ $box_h -gt $max_h ]] && box_h=$max_h
            list_h=$((box_h - 6)); [[ $list_h -lt 4 ]] && list_h=4
            picked=$(dialog --title "$TITLE — ${M[playlist]} ($count ${M[word_videos]})" \
                --extra-button --extra-label "${M[btn_step_back]}" --cancel-label "${M[btn_cancel]}" \
                --checklist "${M[checklist_hint]}" $box_h 74 $list_h \
                "${checklist_args[@]}" 3>&1 1>&2 2>&3)
            nav=$(nav_action $?)
            if [[ "$nav" == "next" ]]; then
                if [[ -z "$picked" ]]; then
                    dialog --title "$TITLE" --msgbox "${M[err_no_pick]}" 7 50; nav="stay"
                else
                    yt_sel=$(echo "$picked" | tr -d '"' | tr ' ' ',')
                    playlist_args=(--yes-playlist --playlist-items "$yt_sel")
                fi
            fi
        fi
        ;;

    format)
        sel=$(dialog --title "$TITLE" --default-item "${format:-mp3}" \
            --extra-button --extra-label "${M[btn_step_back]}" --cancel-label "${M[btn_cancel]}" \
            --menu "${M[format_q]}" 12 40 2 \
            "mp3" "${M[opt_audio]}" \
            "mp4" "${M[opt_video]}" 3>&1 1>&2 2>&3)
        nav=$(nav_action $?)
        [[ "$nav" == "next" ]] && format="$sel"   # keep prior pick on Back/Anuluj
        ;;

    quality)
        cur_fmt="${format:-${DEFAULT_FORMAT:-mp4}}"
        if [[ "$cur_fmt" == "mp4" ]]; then
            sel=$(dialog --title "$TITLE" --default-item "${quality:-best}" \
                --extra-button --extra-label "${M[btn_step_back]}" --cancel-label "${M[btn_cancel]}" \
                --menu "${M[video_quality_q]}" 19 52 8 \
                "best" "${M[opt_best]}" \
                "4320" "4320p (8K)" \
                "2160" "2160p (4K)" \
                "1440" "1440p (2K)" \
                "1080" "1080p (Full HD)" \
                "720" "720p (HD)" \
                "480" "480p (SD)" \
                "360" "360p" 3>&1 1>&2 2>&3)
        else
            sel=$(dialog --title "$TITLE" --default-item "${quality:-320}" \
                --extra-button --extra-label "${M[btn_step_back]}" --cancel-label "${M[btn_cancel]}" \
                --menu "${M[audio_quality_q]}" 14 50 3 \
                "320" "${M[q320]}" \
                "192" "192 kbps" \
                "128" "128 kbps" 3>&1 1>&2 2>&3)
        fi
        nav=$(nav_action $?)
        [[ "$nav" == "next" ]] && quality="$sel"
        ;;

    preview)
        if [[ -z "$fetched" ]]; then
            dialog --title "$TITLE" --infobox "${M[info_fetching]}" 5 40
            info=$(yt-dlp --no-playlist --print "%(title)s\n%(duration_string)s\n%(filesize_approx,filesize)s" "$url" 2>/dev/null)
            v_title=$(echo "$info" | sed -n '1p')
            v_duration=$(echo "$info" | sed -n '2p')
            v_size=$(echo "$info" | sed -n '3p')
            if [[ -z "$v_title" ]]; then    # yt-dlp couldn't resolve it → bad/dead URL
                dialog --title "$TITLE" --msgbox "${M[err_url]}" 7 60
                nav="cancel"
            else
                [[ "$v_size" == "NA" || -z "$v_size" ]] && v_size="${M[size_unknown]}" || v_size=$(human_size "$v_size")
                fetched=1
            fi
        fi
        if [[ -z "$nav" ]]; then
            cur_fmt="${format:-${DEFAULT_FORMAT:-mp4}}"
            cur_q="$quality"
            [[ -z "$cur_q" ]] && { [[ "$cur_fmt" == "mp4" ]] && cur_q="${DEFAULT_QUALITY:-best}" || cur_q="${DEFAULT_QUALITY:-320}"; }
            dialog --title "$TITLE — ${M[preview_title]}" \
                --yes-label "${M[btn_download]}" --extra-button --extra-label "${M[btn_step_back]}" --cancel-label "${M[btn_cancel]}" \
                --yesno "$(printf "${M[preview_body]}" "$v_title" "$v_duration" "$v_size" "$cur_fmt" "$cur_q")" 12 70
            nav=$(nav_action $?)
        fi
        ;;

    esac

    case "$nav" in
        next)   i=$((i+1)) ;;
        back)   i=$((i-1)) ;;       # i=-1 on first step → handled as "back to URL" below
        stay)   : ;;                # validation failed → redisplay same step
        cancel) i=-1 ;;
        exit)   rm -f "${spot_save:-}"; exit 0 ;;
        *)      i=-1 ;;
    esac
done

# Wstecz-from-first / Anuluj / fetch error → re-prompt URL (link still in the field).
# Reset last_url so re-entering the same link re-fetches (we just deleted spot_save).
[[ $i -lt 0 ]] && { rm -f "${spot_save:-}"; last_url=""; continue; }

# ── all decision steps passed → finalize + download + summary ──
if [[ "$branch" == "spotify" ]]; then
    spot_picked="/tmp/dlmedia_spot_picked_$$.spotdl"
    IFS=',' read -ra _sel <<< "$spot_sel"; sel_count=${#_sel[@]}
    if [[ "$sel_count" -ge "$spot_count" ]]; then
        spot_query="$url"
    else
        new_count=$(python3 "$SCRIPT_DIR/tools/spotdl_filter.py" "$spot_save" "$spot_sel" "$spot_picked" 2>/dev/null)
        [[ -z "$new_count" || "$new_count" -eq 0 ]] && { rm -f "$spot_save" "$spot_picked"; dialog --title "$TITLE" --msgbox "${M[err_spot_list]}" 7 50; continue; }
        spot_count="$new_count"; spot_query="$spot_picked"
    fi
    overwrite_args=()
    if [[ "$PLAYLIST_SUBFOLDERS" == true ]]; then
        spot_output="${DOWNLOAD_DIR}/{list-name}/{artist} - {title}"
    else
        spot_output="${DOWNLOAD_DIR}/{artist} - {title}"
    fi
    list_name=$(python3 -c "import json; data=json.load(open('$spot_save')); print(data[0].get('list_name',''))" 2>/dev/null)
    existing=$(find "${DOWNLOAD_DIR}/${list_name}" -name "*.mp3" 2>/dev/null | head -1)
    if [[ -n "$list_name" && -n "$existing" ]]; then
        ow_mode=$(dialog --title "$TITLE" --cancel-label "${M[btn_cancel]}" --menu "${M[ow_q]}" 12 55 2 \
            "skip" "${M[ow_skip]}" \
            "overwrite" "${M[ow_overwrite]}" 3>&1 1>&2 2>&3)
        if [[ "$(nav_action $?)" == "next" ]]; then
            [[ "$ow_mode" == "skip" ]] && overwrite_args=(--skip-existing)
        else
            rm -f "$spot_save" "$spot_picked"; continue
        fi
    fi
    log="/tmp/dlmedia_spot_$$.log"
    stdbuf -oL spotdl "${overwrite_args[@]}" --bitrate "${quality:-320}k" --output "$spot_output" "$spot_query" 2>&1 | tee "$log" | dialog --title "$TITLE — ${M[downloading]} ($spot_count ${M[word_tracks]})" --programbox 20 78
    downloaded=$(grep -c "^Downloaded" "$log" || echo 0)
    # Per-item failure report over the attempted tracks (selected subset, or all).
    attempted=()
    if [[ "$spot_query" == "$url" ]]; then
        attempted=("${spot_tracks[@]}")
    else
        IFS=',' read -ra _sel <<< "$spot_sel"
        for _n in "${_sel[@]}"; do attempted+=("${spot_tracks[$((_n-1))]}"); done
    fi
    tracks_file="/tmp/dlmedia_tracks_$$.txt"; printf '%s\n' "${attempted[@]}" > "$tracks_file"
    report_file="/tmp/dlmedia_report_$$.txt"
    nfail=$(python3 "$SCRIPT_DIR/tools/dl_report.py" spot "$log" "$tracks_file" "$report_file" 2>/dev/null); [[ -z "$nfail" ]] && nfail=0
    rm -f "$log" "$spot_save" "$spot_picked" "$tracks_file"
    summary="$(printf "${M[summary_spot]}" "$downloaded" "$spot_count")"
    summary_w=70
else
    format="${format:-${DEFAULT_FORMAT:-mp4}}"
    if [[ -z "$quality" ]]; then
        [[ "$format" == "mp4" ]] && quality="${DEFAULT_QUALITY:-best}" || quality="${DEFAULT_QUALITY:-320}"
    fi
    build_yt_args "$format" "$quality"

    ow_mode=""
    if [[ "$branch" == "ytlist" ]]; then
        if [[ "$PLAYLIST_SUBFOLDERS" == true ]]; then
            output="${DOWNLOAD_DIR}/%(playlist_title)s/%(title)s.%(ext)s"
        else
            output="${DOWNLOAD_DIR}/%(title)s.%(ext)s"
        fi
        pl_name=$(yt-dlp --flat-playlist --print "%(playlist_title)s" "$url" 2>/dev/null | head -1)
        existing=$(find "${DOWNLOAD_DIR}/${pl_name}" -name "*.mp4" -o -name "*.mp3" 2>/dev/null | head -1)
        if [[ -n "$pl_name" && -n "$existing" ]]; then
            ow_mode=$(dialog --title "$TITLE" --cancel-label "${M[btn_cancel]}" --menu "${M[ow_q]}" 12 55 2 \
                "skip" "${M[ow_skip]}" \
                "overwrite" "${M[ow_overwrite]}" 3>&1 1>&2 2>&3)
            [[ "$(nav_action $?)" != "next" ]] && continue
        fi
    else
        output="${DOWNLOAD_DIR}/%(title)s.%(ext)s"
    fi

    yt_extra_args=()
    [[ "$ow_mode" == "skip" ]] && yt_extra_args=(--download-archive "${DOWNLOAD_DIR}/.ytdl-archive")

    log="/tmp/dlmedia_yt_$$.log"
    dl_title="${M[downloading]}"
    [[ "$branch" == "ytlist" ]] && dl_title="${M[downloading]} (${count:-} ${M[word_videos]})"
    stdbuf -oL yt-dlp --newline "${playlist_args[@]}" "${args[@]}" "${yt_extra_args[@]}" -o "$output" "$url" 2>&1 | tee "$log" | dialog --title "$TITLE — $dl_title" --programbox 20 78
    downloaded=$(grep -c "\[download\] Destination:" "$log" 2>/dev/null || true)
    skipped=$(grep -c "has already been recorded" "$log" 2>/dev/null || true)
    [[ -z "$downloaded" ]] && downloaded=0
    [[ -z "$skipped" ]] && skipped=0
    report_file="/tmp/dlmedia_report_$$.txt"
    nfail=$(python3 "$SCRIPT_DIR/tools/dl_report.py" yt "$log" "${yt_ids_file:-/dev/null}" "$report_file" 2>/dev/null); [[ -z "$nfail" ]] && nfail=0
    rm -f "$log"
    summary="$(printf "${M[summary_yt]}" "$downloaded" "$skipped")"
    summary_w=80
fi

# Summary body: success line, or a short ✗ list of failed items (full "title → error"
# detail is behind "Pokaż logi", which reads $report_file built by tools/dl_report.py).
body_lines=1
if [[ "${nfail:-0}" -gt 0 ]]; then
    summary+="\n\n$(printf "${M[summary_failed_hdr]}" "$nfail")"
    short=$(grep -v '^   ' "$report_file" 2>/dev/null | grep -v '^[[:space:]]*$' | head -10)
    nshort=$(printf '%s' "$short" | grep -c .)
    while IFS= read -r _h; do [[ -n "$_h" ]] && summary+="\n  ✗ $_h"; done <<< "$short"
    body_lines=$((nshort + 2))
    if [[ "$nfail" -gt "$nshort" ]]; then
        summary+="\n  $(printf "${M[summary_more]}" "$((nfail - nshort))")"
        body_lines=$((body_lines + 1))
    fi
else
    summary+="\n\n${M[summary_all_ok]}"
fi

# Download finished → invalidate cache so re-running the same URL re-fetches.
last_url=""
# Summary screen: Powrót (→URL) / Pokaż logi (→error page) / Exit. Loop so the log view returns here.
max_h=$(($(tput lines) - 2)); h=$((body_lines + 9)); [[ $h -gt $max_h ]] && h=$max_h
while :; do
    if [[ "${nfail:-0}" -gt 0 ]]; then
        dialog --title "$TITLE — ${M[summary_title]}" \
            --yes-label "${M[btn_back]}" --extra-button --extra-label "${M[btn_show_logs]}" --no-label "Exit" --defaultno \
            --yesno "$summary" "$h" "$summary_w"
    else
        dialog --title "$TITLE — ${M[summary_title]}" \
            --yes-label "${M[btn_back]}" --no-label "Exit" --defaultno \
            --yesno "$summary" "$h" "$summary_w"
    fi
    case "$(nav_action $?)" in
        next) break ;;                                   # Powrót → re-prompt URL
        back) dialog --title "$TITLE — ${M[logs_title]}" --exit-label "${M[btn_close]}" \
                  --textbox "$report_file" "$max_h" 78 ;;   # Pokaż logi; Enter/Esc → back to summary
        *)    rm -f "${report_file:-}" "${yt_ids_file:-}"; exit 0 ;;   # Exit / Esc
    esac
done
rm -f "${report_file:-}" "${yt_ids_file:-}"; yt_ids_file=""
continue

done
